{
	"name": "pauldro/minicli-v1-database",
	"description": "Minicli Extenders with utilities",
	"type": "library",
	"keywords": ["php", "cli", "php-cli", "minicli"],
	"license": "MIT",
	"minimum-stability": "dev",
	"config": {
		"platform": {
			"php": "7.4"
		}
	},
	"autoload": {
		"psr-4": {
			"Pauldro\\Minicli\\Database\\": "src/"
		}
	},
	"require": {
		"minicli/minicli": "v2.0.x-dev",
		"pauldro/minicli-v1": "dev-main",
		"propel/propel": "v2.0.0-alpha11",
		"sergeytsalkov/meekrodb": "dev-master"
	},
	"require-dev": {
		"minicli/minicli": "v2.0.x-dev",
		"pauldro/minicli-v1": "dev-main",
		"sergeytsalkov/meekrodb": "dev-master",
		"propel/propel": "v2.0.0-alpha11"
	}
}
